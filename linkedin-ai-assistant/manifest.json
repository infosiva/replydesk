{
  "manifest_version": 3,
  "name": "LinkedIn AI Assistant",
  "version": "1.0.0",
  "description": "Auto-apply to jobs on LinkedIn + AI-powered comments, summaries, and automation",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://api.groq.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": [
        "src/content/content-script.js",
        "src/content/job-auto-apply.js",
        "src/content/linkedin-automation.js"
      ],
      "css": ["src/content/content-styles.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/content/content-styles.css"],
      "matches": ["https://*.linkedin.com/*"]
    }
  ]
}
