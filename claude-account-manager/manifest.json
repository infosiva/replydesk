{
  "manifest_version": 3,
  "name": "Claude Account Manager",
  "version": "1.0.0",
  "description": "Monitor usage, track limits, and manage multiple Claude accounts with smart switching",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/content/content-script.js"],
      "css": ["src/content/content-styles.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "public/icon16.png",
      "48": "public/icon48.png",
      "128": "public/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["src/content/content-styles.css"],
      "matches": ["https://claude.ai/*"]
    }
  ]
}
