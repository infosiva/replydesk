{
  "name": "@infosiva/shared-ui",
  "version": "1.3.0",
  "description": "Shared UI components, auth, chatbot, and motion primitives for all siva's projects",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles/themes.css": "./src/styles/themes.css",
    "./lib/analytics": {
      "types": "./dist/lib/analytics.d.ts",
      "import": "./dist/lib/analytics.mjs",
      "require": "./dist/lib/analytics.js"
    },
    "./lib/createFeedbackRoute": {
      "types": "./dist/lib/createFeedbackRoute.d.ts",
      "import": "./dist/lib/createFeedbackRoute.mjs",
      "require": "./dist/lib/createFeedbackRoute.js"
    },
    "./lib/createChatRoute": {
      "types": "./dist/lib/createChatRoute.d.ts",
      "import": "./dist/lib/createChatRoute.mjs",
      "require": "./dist/lib/createChatRoute.js"
    },
    "./lib/flags": {
      "types": "./dist/lib/flags.d.ts",
      "import": "./dist/lib/flags.mjs",
      "require": "./dist/lib/flags.js"
    },
    "./lib/rateLimit": {
      "types": "./dist/lib/rateLimit.d.ts",
      "import": "./dist/lib/rateLimit.mjs",
      "require": "./dist/lib/rateLimit.js"
    }
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup src/index.ts src/lib/analytics.ts src/lib/createFeedbackRoute.ts src/lib/createChatRoute.ts src/lib/flags.ts src/lib/rateLimit.ts --format cjs,esm --dts --clean --external react --external next --external framer-motion",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "framer-motion": ">=10",
    "next": ">=14",
    "react": ">=18"
  },
  "devDependencies": {
    "@fal-ai/client": "^1.10.1",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/kv": "^3.0.0",
    "framer-motion": "^11.18.2",
    "next": "^16.2.6",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "groq-sdk": "^1.2.0",
    "lucide-react": "^1.16.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/infosiva/replydesk.git",
    "directory": "shared-ui"
  }
}
